{
    "info": {
        "_postman_id": "order-payment-api-collection",
        "name": "Order & Payment Management API",
        "description": "Complete API documentation for the Order & Payment Management system. Built with Laravel 13, JWT Auth, and Strategy Pattern for extensible payment gateways.\n\n## Setup\n1. Import this collection into Postman\n2. Set the `base_url` variable to your API URL (e.g. `http://localhost:8000`)\n3. Register a user or login to get a token — it auto-saves to `{{token}}`",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "http://localhost:8000",
            "type": "string"
        },
        {
            "key": "token",
            "value": "",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "Auth",
            "description": "User registration, login, profile, and logout endpoints",
            "item": [
                {
                    "name": "Register",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Accept", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"password_confirmation\": \"password123\"\n}"
                        },
                        "url": "{{base_url}}/api/auth/register",
                        "description": "Register a new user. Returns a JWT token."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 201) {",
                                    "  const json = pm.response.json();",
                                    "  pm.collectionVariables.set('token', json.data.access_token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "response": [
                        {
                            "name": "201 Created — Success",
                            "status": "Created",
                            "code": 201,
                            "body": "{\n  \"data\": {\n    \"user\": {\n      \"id\": 1,\n      \"name\": \"John Doe\",\n      \"email\": \"john@example.com\"\n    },\n    \"access_token\": \"eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...\",\n    \"token_type\": \"bearer\",\n    \"expires_in\": 3600\n  }\n}"
                        },
                        {
                            "name": "422 Validation Error",
                            "status": "Unprocessable Entity",
                            "code": 422,
                            "body": "{\n  \"message\": \"The email has already been taken.\",\n  \"errors\": {\n    \"email\": [\"This email is already registered.\"]\n  }\n}"
                        }
                    ]
                },
                {
                    "name": "Login",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Accept", "value": "application/json" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
                        },
                        "url": "{{base_url}}/api/auth/login",
                        "description": "Authenticate and receive a JWT token."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "if (pm.response.code === 200) {",
                                    "  const json = pm.response.json();",
                                    "  pm.collectionVariables.set('token', json.data.access_token);",
                                    "}"
                                ],
                                "type": "text/javascript"
                            }
                        }
                    ],
                    "response": [
                        {
                            "name": "200 OK — Success",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"data\": {\n    \"user\": { \"id\": 1, \"name\": \"John Doe\", \"email\": \"john@example.com\" },\n    \"access_token\": \"eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...\",\n    \"token_type\": \"bearer\",\n    \"expires_in\": 3600\n  }\n}"
                        },
                        {
                            "name": "401 Unauthorized — Wrong Credentials",
                            "status": "Unauthorized",
                            "code": 401,
                            "body": "{\n  \"message\": \"Invalid credentials. Please check your email and password.\"\n}"
                        }
                    ]
                },
                {
                    "name": "Me (Get Profile)",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "url": "{{base_url}}/api/auth/me",
                        "description": "Get the authenticated user's profile."
                    },
                    "response": [
                        {
                            "name": "200 OK",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"data\": { \"id\": 1, \"name\": \"John Doe\", \"email\": \"john@example.com\" }\n}"
                        },
                        {
                            "name": "401 Unauthorized",
                            "status": "Unauthorized",
                            "code": 401,
                            "body": "{ \"message\": \"Unauthenticated.\" }"
                        }
                    ]
                },
                {
                    "name": "Logout",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "url": "{{base_url}}/api/auth/logout",
                        "description": "Invalidate the current JWT token."
                    },
                    "response": [
                        {
                            "name": "200 OK",
                            "status": "OK",
                            "code": 200,
                            "body": "{ \"message\": \"Successfully logged out.\" }"
                        }
                    ]
                },
                {
                    "name": "Refresh Token",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "url": "{{base_url}}/api/auth/refresh",
                        "description": "Refresh the JWT token before it expires."
                    },
                    "response": [
                        {
                            "name": "200 OK — New Token",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"data\": {\n    \"user\": { \"id\": 1, \"name\": \"John Doe\", \"email\": \"john@example.com\" },\n    \"access_token\": \"eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...NEW\",\n    \"token_type\": \"bearer\",\n    \"expires_in\": 3600\n  }\n}"
                        }
                    ]
                }
            ]
        },
        {
            "name": "Orders",
            "description": "Order CRUD endpoints. Orders can be filtered by status. Deletion is blocked if payments exist.",
            "item": [
                {
                    "name": "List Orders",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/orders?status=pending&per_page=15",
                            "host": ["{{base_url}}"],
                            "path": ["api", "orders"],
                            "query": [
                                { "key": "status", "value": "pending", "description": "Filter by status: pending, confirmed, cancelled" },
                                { "key": "per_page", "value": "15", "description": "Items per page (max 100)" }
                            ]
                        },
                        "description": "List all orders with optional status filter and pagination."
                    },
                    "response": [
                        {
                            "name": "200 OK — Paginated List",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"data\": [\n    {\n      \"id\": 1,\n      \"user_id\": 1,\n      \"user\": { \"id\": 1, \"name\": \"John Doe\", \"email\": \"john@example.com\" },\n      \"items\": [\n        { \"name\": \"Widget A\", \"quantity\": 2, \"price\": 25.00 }\n      ],\n      \"total\": 50.00,\n      \"status\": \"pending\",\n      \"created_at\": \"2026-06-25T12:00:00+00:00\",\n      \"updated_at\": \"2026-06-25T12:00:00+00:00\"\n    }\n  ],\n  \"links\": { \"first\": \"...\", \"last\": \"...\", \"prev\": null, \"next\": null },\n  \"meta\": { \"current_page\": 1, \"last_page\": 1, \"per_page\": 15, \"total\": 1 }\n}"
                        },
                        {
                            "name": "422 Invalid Status Filter",
                            "status": "Unprocessable Entity",
                            "code": 422,
                            "body": "{\n  \"message\": \"The selected status is invalid.\",\n  \"errors\": { \"status\": [\"The selected status is invalid.\"] }\n}"
                        }
                    ]
                },
                {
                    "name": "Create Order",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"items\": [\n    { \"name\": \"Widget A\", \"quantity\": 2, \"price\": 25.00 },\n    { \"name\": \"Widget B\", \"quantity\": 1, \"price\": 10.00 }\n  ]\n}"
                        },
                        "url": "{{base_url}}/api/orders",
                        "description": "Create a new order. Total is auto-calculated from items."
                    },
                    "response": [
                        {
                            "name": "201 Created — Success",
                            "status": "Created",
                            "code": 201,
                            "body": "{\n  \"message\": \"Order created successfully.\",\n  \"data\": {\n    \"id\": 1,\n    \"user_id\": 1,\n    \"items\": [\n      { \"name\": \"Widget A\", \"quantity\": 2, \"price\": 25.00 },\n      { \"name\": \"Widget B\", \"quantity\": 1, \"price\": 10.00 }\n    ],\n    \"total\": 60.00,\n    \"status\": \"pending\",\n    \"created_at\": \"2026-06-25T12:00:00+00:00\",\n    \"updated_at\": \"2026-06-25T12:00:00+00:00\"\n  }\n}"
                        },
                        {
                            "name": "422 Validation Error",
                            "status": "Unprocessable Entity",
                            "code": 422,
                            "body": "{\n  \"message\": \"At least one item is required.\",\n  \"errors\": { \"items\": [\"At least one item is required.\"] }\n}"
                        }
                    ]
                },
                {
                    "name": "Get Order",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "url": "{{base_url}}/api/orders/1",
                        "description": "Retrieve a single order by ID."
                    },
                    "response": [
                        {
                            "name": "200 OK",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"data\": {\n    \"id\": 1,\n    \"user_id\": 1,\n    \"user\": { \"id\": 1, \"name\": \"John Doe\", \"email\": \"john@example.com\" },\n    \"items\": [{ \"name\": \"Widget A\", \"quantity\": 2, \"price\": 25.00 }],\n    \"total\": 50.00,\n    \"status\": \"pending\",\n    \"created_at\": \"2026-06-25T12:00:00+00:00\",\n    \"updated_at\": \"2026-06-25T12:00:00+00:00\"\n  }\n}"
                        },
                        {
                            "name": "404 Not Found",
                            "status": "Not Found",
                            "code": 404,
                            "body": "{ \"message\": \"No query results for model [App\\\\Models\\\\Order].\" }"
                        }
                    ]
                },
                {
                    "name": "Update Order",
                    "request": {
                        "method": "PUT",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"status\": \"confirmed\"\n}"
                        },
                        "url": "{{base_url}}/api/orders/1",
                        "description": "Update an existing order. Recalculates total if items are updated."
                    },
                    "response": [
                        {
                            "name": "200 OK — Updated",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"message\": \"Order updated successfully.\",\n  \"data\": { \"id\": 1, \"status\": \"confirmed\", \"total\": 50.00, ... }\n}"
                        }
                    ]
                },
                {
                    "name": "Delete Order",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "url": "{{base_url}}/api/orders/1",
                        "description": "Delete an order. **Blocked if the order has any payments.**"
                    },
                    "response": [
                        {
                            "name": "200 OK — Deleted",
                            "status": "OK",
                            "code": 200,
                            "body": "{ \"message\": \"Order deleted successfully.\" }"
                        },
                        {
                            "name": "422 Has Payments — Cannot Delete",
                            "status": "Unprocessable Entity",
                            "code": 422,
                            "body": "{ \"message\": \"Order cannot be deleted because it has associated payments.\" }"
                        }
                    ]
                }
            ]
        },
        {
            "name": "Payments",
            "description": "Payment processing and retrieval. Only confirmed orders can be paid.",
            "item": [
                {
                    "name": "List Payments",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/payments?order_id=1&per_page=15",
                            "host": ["{{base_url}}"],
                            "path": ["api", "payments"],
                            "query": [
                                { "key": "order_id", "value": "1", "description": "Filter payments by order ID" },
                                { "key": "per_page", "value": "15" }
                            ]
                        },
                        "description": "List all payments, optionally filtered by order_id."
                    },
                    "response": [
                        {
                            "name": "200 OK — Paginated",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"data\": [\n    {\n      \"id\": 1,\n      \"order_id\": 1,\n      \"payment_method\": \"credit_card\",\n      \"status\": \"successful\",\n      \"gateway_response\": {\n        \"gateway\": \"credit_card\",\n        \"transaction_id\": \"CC-ABCDEF123456\",\n        \"amount\": 60.00,\n        \"currency\": \"USD\",\n        \"status\": \"approved\",\n        \"processed_at\": \"2026-06-25T12:00:00+00:00\"\n      },\n      \"created_at\": \"2026-06-25T12:00:00+00:00\",\n      \"updated_at\": \"2026-06-25T12:00:00+00:00\"\n    }\n  ],\n  \"meta\": { \"current_page\": 1, \"total\": 1, \"per_page\": 15 }\n}"
                        }
                    ]
                },
                {
                    "name": "Process Payment (Credit Card)",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "Idempotency-Key", "value": "{{$guid}}", "description": "Optional: Prevents duplicate payments" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"order_id\": 1,\n  \"payment_method\": \"credit_card\"\n}"
                        },
                        "url": "{{base_url}}/api/payments",
                        "description": "Process a payment using the Credit Card gateway. Order must be `confirmed`."
                    },
                    "response": [
                        {
                            "name": "201 Created — Payment Successful",
                            "status": "Created",
                            "code": 201,
                            "body": "{\n  \"message\": \"Payment processed successfully.\",\n  \"data\": {\n    \"id\": 1,\n    \"order_id\": 1,\n    \"payment_method\": \"credit_card\",\n    \"status\": \"successful\",\n    \"gateway_response\": {\n      \"gateway\": \"credit_card\",\n      \"transaction_id\": \"CC-XYZ789ABC123\",\n      \"order_id\": 1,\n      \"amount\": 60.00,\n      \"currency\": \"USD\",\n      \"status\": \"approved\",\n      \"processed_at\": \"2026-06-25T12:00:00+00:00\"\n    },\n    \"created_at\": \"2026-06-25T12:00:00+00:00\",\n    \"updated_at\": \"2026-06-25T12:00:00+00:00\"\n  }\n}"
                        },
                        {
                            "name": "422 Order Not Confirmed",
                            "status": "Unprocessable Entity",
                            "code": 422,
                            "body": "{ \"message\": \"Payments can only be processed for orders with status [confirmed]. Current status: [pending].\" }"
                        },
                        {
                            "name": "422 Invalid Payment Method",
                            "status": "Unprocessable Entity",
                            "code": 422,
                            "body": "{\n  \"message\": \"The selected payment method is invalid.\",\n  \"errors\": { \"payment_method\": [\"Payment method must be one of: credit_card, paypal, stripe.\"] }\n}"
                        }
                    ]
                },
                {
                    "name": "Process Payment (PayPal)",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "Idempotency-Key", "value": "{{$guid}}", "description": "Optional: Prevents duplicate payments" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"order_id\": 1,\n  \"payment_method\": \"paypal\"\n}"
                        },
                        "url": "{{base_url}}/api/payments",
                        "description": "Process a payment using the PayPal gateway."
                    },
                    "response": [
                        {
                            "name": "201 Created — PayPal Success",
                            "status": "Created",
                            "code": 201,
                            "body": "{\n  \"message\": \"Payment processed successfully.\",\n  \"data\": {\n    \"id\": 2,\n    \"order_id\": 1,\n    \"payment_method\": \"paypal\",\n    \"status\": \"successful\",\n    \"gateway_response\": {\n      \"gateway\": \"paypal\",\n      \"transaction_id\": \"PAYPAL-ABCDE12345\",\n      \"payer_id\": \"PAYER-XYZWQRST\",\n      \"amount\": 60.00,\n      \"currency\": \"USD\",\n      \"status\": \"COMPLETED\",\n      \"mode\": \"sandbox\"\n    }\n  }\n}"
                        }
                    ]
                },
                {
                    "name": "Process Payment (Stripe)",
                    "request": {
                        "method": "POST",
                        "header": [
                            { "key": "Content-Type", "value": "application/json" },
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" },
                            { "key": "Idempotency-Key", "value": "{{$guid}}", "description": "Optional: Prevents duplicate payments" }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"order_id\": 1,\n  \"payment_method\": \"stripe\"\n}"
                        },
                        "url": "{{base_url}}/api/payments",
                        "description": "Process a payment using the Stripe gateway (demonstrates extensibility)."
                    },
                    "response": [
                        {
                            "name": "201 Created — Stripe Success",
                            "status": "Created",
                            "code": 201,
                            "body": "{\n  \"message\": \"Payment processed successfully.\",\n  \"data\": {\n    \"id\": 3,\n    \"order_id\": 1,\n    \"payment_method\": \"stripe\",\n    \"status\": \"successful\",\n    \"gateway_response\": {\n      \"gateway\": \"stripe\",\n      \"charge_id\": \"ch_AbCdEfGhIjKlMnOpQrStUvWx\",\n      \"object\": \"charge\",\n      \"amount\": 6000,\n      \"currency\": \"usd\",\n      \"status\": \"succeeded\",\n      \"livemode\": false\n    }\n  }\n}"
                        }
                    ]
                },
                {
                    "name": "Get Payment",
                    "request": {
                        "method": "GET",
                        "header": [
                            { "key": "Accept", "value": "application/json" },
                            { "key": "Authorization", "value": "Bearer {{token}}" }
                        ],
                        "url": "{{base_url}}/api/payments/1",
                        "description": "Retrieve a single payment by ID."
                    },
                    "response": [
                        {
                            "name": "200 OK",
                            "status": "OK",
                            "code": 200,
                            "body": "{\n  \"data\": {\n    \"id\": 1,\n    \"order_id\": 1,\n    \"payment_method\": \"credit_card\",\n    \"status\": \"successful\",\n    \"gateway_response\": { ... },\n    \"created_at\": \"2026-06-25T12:00:00+00:00\"\n  }\n}"
                        }
                    ]
                }
            ]
        }
    ]
}
